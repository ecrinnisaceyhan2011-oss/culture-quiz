<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nisa | Culture Quiz 🥨</title>
    <style>
        body {
            margin: 0; padding: 0;
            background: #fff5f8;
            font-family: 'Segoe UI', sans-serif;
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; min-height: 100vh;
        }
        .quiz-card {
            background: white;
            padding: 30px;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(248, 187, 208, 0.3);
            text-align: center;
            width: 90%; max-width: 450px;
        }
        h1 { color: #880e4f; margin-bottom: 20px; }
        .question { font-size: 20px; font-weight: 600; color: #5d4037; margin-bottom: 25px; }
        
        .options { display: flex; flex-direction: column; gap: 15px; }
        .option-btn {
            background: #fce4ec;
            border: 2px solid #f8bbd0;
            padding: 15px;
            border-radius: 15px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
            color: #880e4f;
            font-weight: 600;
        }
        .option-btn:hover { background: #f8bbd0; transform: scale(1.02); }
        
        #score-board { margin-top: 25px; font-size: 20px; font-weight: 700; color: #ad1457; }
        #feedback { margin-top: 15px; font-weight: 600; min-height: 30px; }
        
        .restart-btn {
            margin-top: 20px;
            background: #880e4f;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            cursor: pointer;
            display: none; /* Sadece bitince görünecek */
        }
    </style>
</head>
<body>

    <div class="quiz-card" id="main-card">
        <h1>Türk Kültürü Testi 🥨</h1>
        
        <div id="quiz-content">
            <div class="question" id="question-text">Soru Yükleniyor...</div>
            <div class="options" id="options-area"></div>
        </div>

        <div id="feedback"></div>
        <div id="score-board">Puan: 0</div>
        <button class="restart-btn" id="restart" onclick="location.reload()">Tekrar Oyna 🔄</button>
    </div>

    <script>
        const myQuestions = [
            { q: "Hangi yiyecek Türk kültüründe 'gevrek' olarak da bilinir?", a: ["Pizza", "Simit 🥨", "Kek"], correct: 1 },
            { q: "Türkiye'nin başkenti neresidir?", a: ["İstanbul", "Ankara 🇹🇷", "İzmir"], correct: 1 },
            { q: "Geleneksel bir Türk içeceği hangisidir?", a: ["Ayran 🥛", "Kola", "Limonata"], correct: 0 },
            { q: "Hangi şehir dondurmasıyla meşhurdur?", a: ["Kahramanmaraş 🍦", "Adana", "Antalya"], correct: 0 }
        ];

        let currentIdx = 0;
        let myScore = 0;

        function showQuestion() {
            const currentQ = myQuestions[currentIdx];
            document.getElementById('question-text').innerText = currentQ.q;
            const area = document.getElementById('options-area');
            area.innerHTML = "";
            document.getElementById('feedback').innerText = "";

            currentQ.a.forEach((opt, i) => {
                const b = document.createElement('button');
                b.className = 'option-btn';
                b.innerText = opt;
                b.onclick = () => check(i);
                area.appendChild(b);
            });
        }

        function check(selected) {
            const feed = document.getElementById('feedback');
            if (selected === myQuestions[currentIdx].correct) {
                myScore += 10;
                feed.innerText = "Harika! Doğru ✅";
                feed.style.color = "#4caf50";
            } else {
                feed.innerText = "Üzgünüm, Yanlış! ❌";
                feed.style.color = "#f44336";
            }

            document.getElementById('score-board').innerText = "Puan: " + myScore;
            
            currentIdx++;
            if (currentIdx < myQuestions.length) {
                setTimeout(showQuestion, 1200); 
            } else {
                setTimeout(() => {
                    document.getElementById('quiz-content').innerHTML = "<h2>Test Bitti! 🏆</h2>";
                    document.getElementById('restart').style.display = "inline-block";
                }, 1000);
            }
        }

        // Sayfa açılır açılmaz ilk soruyu getir
        window.onload = showQuestion;
    </script>

</body>
</html>
